# ==============================================================================
# 🔒 GIT ATTRIBUTES - BINARY PROTECTION LAYER
# ==============================================================================
# This file provides an additional layer of protection against binary files
# by explicitly marking certain patterns and forcing git behavior.

# ------------------------------------------------------------------------------
# 🚫 FORCE THESE PATTERNS TO NEVER BE TRACKED
# ------------------------------------------------------------------------------

# Orchestra-specific binaries - Mark as binary to prevent diff attempts
orchestrd* binary
orchestra-dash* binary
apps/backend/orchestrd* binary
apps/tui/orchestra* binary

# General executables - Mark as binary
*.exe binary
*.bin binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.o binary

# Database files - Mark as binary
*.db binary
*.sqlite* binary
warehouse.db* binary

# Sensitive config files - These should never be tracked
.env* text
*.key text
*.pem text

# ------------------------------------------------------------------------------
# 📝 FORCE TEXT HANDLING FOR CODE FILES
# ------------------------------------------------------------------------------

# Ensure these are always treated as text
*.go text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# ------------------------------------------------------------------------------
# 🖼️ BINARY FILE DETECTION
# ------------------------------------------------------------------------------

# Mark these as binary to prevent git from trying to diff them
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.tgz binary

# ------------------------------------------------------------------------------
# 📋 PROTECTION SUMMARY
# ------------------------------------------------------------------------------
# Binary markings ensure Git doesn't try to diff these file types
# and handles them appropriately if they somehow get tracked.
#
# Primary protection comes from .gitignore and pre-commit hook!
# ==============================================================================