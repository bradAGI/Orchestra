# Orchestra E2E Test Configuration for Task Deletion Bug Fix
# Test both SQLite (baseline) and GitHub tracker (fix verification)

# Basic settings
ORCHESTRA_API_TOKEN=test-token-e2e
ORCHESTRA_WORKSPACE_ROOT=/tmp/orchestra-e2e-test
ORCHESTRA_HOST=127.0.0.1
ORCHESTRA_PORT=3284

# State configuration
ORCHESTRA_ACTIVE_STATES=Todo,In Progress
ORCHESTRA_TERMINAL_STATES=Done,Cancelled,Closed

# Max concurrent
ORCHESTRA_MAX_CONCURRENT=5

# Test configurations:
# 1. SQLite tracker (baseline - should work)
# ORCHESTRA_TRACKER_TYPE=sqlite

# 2. GitHub tracker (our fix - should now work)
# ORCHESTRA_TRACKER_TYPE=github
# ORCHESTRA_TRACKER_ENDPOINT=your-owner/your-repo
# ORCHESTRA_TRACKER_TOKEN=your-github-token

# Agent settings
ORCHESTRA_AGENT_PROVIDER=CODEX
ORCHESTRA_AGENT_MAX_TURNS=5