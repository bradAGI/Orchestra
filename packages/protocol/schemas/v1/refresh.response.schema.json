{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["queued", "coalesced", "requested_at", "operations"],
  "additionalProperties": false,
  "properties": {
    "queued": {
      "type": "boolean"
    },
    "coalesced": {
      "type": "boolean"
    },
    "requested_at": {
      "type": "string"
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
