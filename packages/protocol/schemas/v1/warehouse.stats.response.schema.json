{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["total_tokens", "total_input", "total_output", "provider_usage", "model_usage", "recent_sessions"],
  "properties": {
    "total_tokens": { "type": "number" },
    "total_input": { "type": "number" },
    "total_output": { "type": "number" },
    "provider_usage": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "model_usage": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "recent_sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "project_id": { "type": "string" },
          "project_name": { "type": "string" },
          "session_uuid": { "type": "string" },
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "branch": { "type": "string" },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" },
          "total_input": { "type": "number" },
          "total_output": { "type": "number" }
        }
      }
    }
  }
}
