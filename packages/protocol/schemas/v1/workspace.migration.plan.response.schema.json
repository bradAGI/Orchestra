{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["from", "to", "result"],
  "additionalProperties": false,
  "properties": {
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "result": {
      "type": "object",
      "required": ["applied", "actions"],
      "additionalProperties": false,
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "source", "target"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "target": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
